generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  CUSTOMER @map("customer")
  OWNER    @map("owner")
  ADMIN    @map("admin")
}

enum MembershipTier {
  SILVER   @map("silver")
  GOLD     @map("gold")
  PLATINUM @map("platinum")
}

enum StayType {
  HOTEL     @map("hotel")
  APARTMENT @map("apartment")
  VILLA     @map("villa")
  RESORT    @map("resort")
}

enum BookingType {
  STAY       @map("stay")
  VEHICLE    @map("vehicle")
  ATTRACTION @map("attraction")
}

enum VehicleServiceMode {
  RIDE_HAILING @map("ride_hailing")
}

enum BookingStatus {
  HOLD                            @map("hold")
  PENDING                         @map("pending")
  CONFIRMED                       @map("confirmed")
  CANCELLED                       @map("cancelled")
  EXPIRED                         @map("expired")
  // Ride-hailing lifecycle statuses
  DRIVER_ACCEPTED                 @map("driver_accepted")
  DRIVER_REJECTED                 @map("driver_rejected")
  ARRIVED                         @map("arrived")
  IN_PROGRESS                     @map("in_progress")
  ONGOING                         @map("ongoing")
  COMPLETION_PENDING_CONFIRMATION @map("completion_pending_confirmation")
  PAYMENT_PENDING                 @map("payment_pending")
  PAID                            @map("paid")
  COMPLETED                       @map("completed")
  CANCELLED_BY_CUSTOMER           @map("cancelled_by_customer")
  CANCELLED_BY_DRIVER             @map("cancelled_by_driver")
}

enum BookingIdempotencyStatus {
  PROCESSING @map("processing")
  SUCCEEDED  @map("succeeded")
  FAILED     @map("failed")
}

enum PaymentStatus {
  PENDING  @map("pending")
  SUCCESS  @map("success")
  FAILED   @map("failed")
  REFUNDED @map("refunded")
}

enum ItemType {
  STAY       @map("stay")
  VEHICLE    @map("vehicle")
  ATTRACTION @map("attraction")
}

enum AccountReviewStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")
}

enum DriverStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")
}

enum VehicleType {
  CAR  @map("car")
  BIKE @map("bike")
  VAN  @map("van")
}

enum ListingModerationStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")
}

enum AuditAction {
  BOOKING_CREATED             @map("booking_created")
  BOOKING_UPDATED             @map("booking_updated")
  BOOKING_STATUS_CHANGED      @map("booking_status_changed")
  BOOKING_CANCELLED           @map("booking_cancelled")
  LISTING_CREATED             @map("listing_created")
  LISTING_UPDATED             @map("listing_updated")
  LISTING_DELETED             @map("listing_deleted")
  LISTING_APPROVED            @map("listing_approved")
  LISTING_REJECTED            @map("listing_rejected")
  OWNER_VERIFICATION_APPROVED @map("owner_verification_approved")
  OWNER_VERIFICATION_REJECTED @map("owner_verification_rejected")
  USER_ROLE_UPDATED           @map("user_role_updated")
}

enum AuditEntityType {
  BOOKING            @map("booking")
  STAY               @map("stay")
  VEHICLE            @map("vehicle")
  ATTRACTION         @map("attraction")
  USER               @map("user")
  OWNER_VERIFICATION @map("owner_verification")
}

enum TicketStatus {
  OPEN   @map("open")
  CLOSED @map("closed")
}

model User {
  id                       String              @id @default(cuid())
  email                    String              @unique
  name                     String
  phone                    String?
  avatarUrl                String?
  passwordHash             String
  role                     UserRole            @default(CUSTOMER)
  membershipTier           MembershipTier      @default(SILVER)
  lifetimeSpend            Decimal             @default(0) @db.Decimal(12, 2)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?
  passwordResetToken       String?
  passwordResetExpires     DateTime?
  passwordChangedAt        DateTime?
  isVerified               Boolean             @default(false)
  ownerStatus              AccountReviewStatus @default(PENDING)
  driverStatus             AccountReviewStatus @default(REJECTED)
  documents                String[]            @default([])
  isDriverOnline           Boolean             @default(false)
  driverCancelCount        Int                 @default(0)
  fcmToken                 String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  ownedStays           Stay[]
  bookings             Booking[]
  payments             Payment[]
  reviews              Review[]
  favorites            Favorite[]
  vehicles             Vehicle[]
  bookingIdempotencies BookingIdempotency[]
  auditLogs            AuditLog[]
  tickets              Ticket[]             @relation("TicketOwner")
  ticketReplies        TicketReply[]        @relation("TicketSender")
  notifications        Notification[]
  driverEarnings       DriverEarning[]
  avatar               UserAvatar?
  userDocuments        UserDocument[]

  @@index([role])
  @@index([emailVerificationToken])
  @@index([emailVerificationExpires])
  @@index([createdAt])
}

model AuditLog {
  id         String          @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType AuditEntityType
  entityId   String
  metadata   Json?
  createdAt  DateTime        @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([action, createdAt])
}

model Stay {
  id               String                  @id @default(cuid())
  ownerId          String
  title            String
  description      String
  type             StayType
  city             String
  country          String
  address          String
  latitude         Decimal                 @db.Decimal(9, 6)
  longitude        Decimal                 @db.Decimal(9, 6)
  images           String[]                @default([])
  amenities        String[]
  policies         Json
  avgRating        Decimal                 @default(0) @db.Decimal(3, 2)
  totalReviews     Int                     @default(0)
  moderationStatus ListingModerationStatus @default(PENDING)
  moderationReason String?
  moderatedAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  rooms    Room[]
  bookings Booking[]
  stayImages StayImage[]

  @@index([ownerId])
  @@index([city, country])
  @@index([type])
  @@index([moderationStatus])
  @@index([ownerId, moderationStatus])
}

model Room {
  id            String   @id @default(cuid())
  stayId        String
  name          String
  pricePerNight Decimal  @db.Decimal(10, 2)
  maxGuests     Int
  bedType       String
  amenities     String[] @default([])
  options       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stay     Stay      @relation(fields: [stayId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookings Booking[]

  @@index([stayId])
  @@index([pricePerNight])
}

model Booking {
  id                   String              @id @default(cuid())
  userId               String
  stayId               String?
  roomId               String?
  // PATCH: Optional linkage for vehicle bookings (non-breaking for stay/room bookings).
  vehicleId            String?
  // PATCH: Optional linkage for attraction bookings (non-breaking for stay/room bookings).
  attractionId         String?
  slotId               String?
  vehicleServiceMode   VehicleServiceMode?
  pickupAddress        String?
  dropoffAddress       String?
  vehicleDistanceKm    Decimal?            @db.Decimal(10, 2)
  vehicleDurationHours Decimal?            @db.Decimal(8, 2)
  type                 BookingType
  checkIn              DateTime
  checkOut             DateTime
  guests               Json
  guestDetails         Json
  totalPrice           Decimal             @db.Decimal(12, 2)
  status               BookingStatus       @default(HOLD)
  expiresAt            DateTime?
  cancelledBy          String?
  cancelReason         String?
  completedAt          DateTime?
  customerConfirmedAt  DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stay               Stay?                @relation(fields: [stayId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  room               Room?                @relation(fields: [roomId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  // PATCH: Relation rules aligned with existing optional booking relations.
  vehicle            Vehicle?             @relation(fields: [vehicleId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  // PATCH: Relation rules aligned with existing optional booking relations.
  attraction         Attraction?          @relation(fields: [attractionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  slot               AttractionSlot?      @relation(fields: [slotId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  payments           Payment[]
  reviews            Review[]
  idempotencyRecords BookingIdempotency[]
  driverEarning      DriverEarning?

  @@index([userId])
  @@index([stayId])
  @@index([roomId])
  @@index([vehicleId])
  @@index([attractionId])
  @@index([slotId])
  @@index([type, status])
  @@index([status, expiresAt])
  @@index([status, checkOut])
  @@index([checkIn, checkOut])
  @@index([createdAt])
}

model BookingIdempotency {
  id             String                   @id @default(cuid())
  userId         String
  idempotencyKey String
  requestHash    String
  status         BookingIdempotencyStatus @default(PROCESSING)
  bookingId      String?
  responseData   Json?
  errorMessage   String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([userId, idempotencyKey])
  @@index([bookingId])
  @@index([status, updatedAt])
}

model Payment {
  id            String        @id @default(cuid())
  bookingId     String
  userId        String
  amount        Decimal       @db.Decimal(12, 2)
  currency      String
  paymentMethod String
  transactionId String?
  receiptUrl    String?
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // PATCH: Service layer must reject creating a second SUCCESS payment for the same booking.
  // PATCH: If stricter DB enforcement is required, add a manual partial unique index in SQL migration:
  // CREATE UNIQUE INDEX ... ON "Payment" ("bookingId") WHERE "status" = 'success';
  // PATCH: Future extension (do not add now): paidAt DateTime?, refundedAt DateTime?

  @@index([bookingId])
  @@index([bookingId, status])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Review {
  id         String    @id @default(cuid())
  userId     String
  bookingId  String
  itemId     String
  itemType   ItemType
  rating     Int       @db.SmallInt
  title      String
  comment    String
  flaggedAt  DateTime?
  flagReason String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  ownerReply String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // PATCH: Service-layer invariant: review itemId/itemType must match the booked item context.
  // PATCH: Future extension (do not add now): deletedAt DateTime? for soft delete.

  @@unique([bookingId, userId])
  @@index([userId])
  @@index([bookingId])
  @@index([itemType, itemId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemType  ItemType
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, itemId, itemType])
  @@index([userId])
  @@index([itemType, itemId])
}

model Vehicle {
  id               String                  @id @default(cuid())
  driverId         String
  type             VehicleType
  brand            String
  model            String
  seats            Int
  pricePerKm       Decimal                 @db.Decimal(10, 2)
  images           String[]                @default([])
  isActive         Boolean                 @default(true)
  title            String?
  description      String?
  serviceMode      VehicleServiceMode      @default(RIDE_HAILING)
  baseFare         Decimal                 @default(0) @db.Decimal(10, 2)
  pricePerHour     Decimal                 @default(0) @db.Decimal(10, 2)
  capacity         Int?
  location         Json?
  city             String?
  latitude         Decimal?               @db.Decimal(9, 6)
  longitude        Decimal?               @db.Decimal(9, 6)
  avgRating        Decimal                 @default(0) @db.Decimal(3, 2)
  totalReviews     Int                     @default(0)
  moderationStatus ListingModerationStatus @default(PENDING)
  moderationReason String?
  moderatedAt      DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  driver   User      @relation(fields: [driverId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookings Booking[]
  vehicleImages VehicleImage[]

  // PATCH: Future extension (do not add now): deletedAt DateTime? for soft delete.

  @@index([driverId])
  @@index([type])
  @@index([isActive])
  @@index([moderationStatus])
  @@index([driverId, moderationStatus])
  @@index([createdAt])
  @@index([city])
  @@index([city, isActive])
  @@index([city, moderationStatus, isActive])
}

model Attraction {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String
  price       Decimal  @db.Decimal(10, 2)
  images      String[] @default([])
  location    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings Booking[]
  slots    AttractionSlot[]
  attractionImages AttractionImage[]

  @@index([type])
  @@index([createdAt])
}

model AttractionSlot {
  id           String   @id @default(cuid())
  attractionId String
  date         DateTime
  startTime    String
  endTime      String
  capacity     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  bookings   Booking[]

  @@unique([attractionId, date, startTime, endTime])
  @@index([attractionId])
  @@index([date])
}

model Ticket {
  id          String       @id @default(cuid())
  userId      String
  subject     String
  message     String
  attachments String[]     @default([])
  status      TicketStatus @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user    User          @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  replies TicketReply[]
  ticketAttachments TicketAttachment[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String
  message   String
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  sender User   @relation("TicketSender", fields: [senderId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([ticketId])
  @@index([senderId])
  @@index([createdAt])
}

model RevokedToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("system")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model DriverEarning {
  id          String   @id @default(cuid())
  driverId    String
  bookingId   String   @unique
  grossAmount Decimal  @db.Decimal(12, 2)
  commission  Decimal  @db.Decimal(12, 2)
  netAmount   Decimal  @db.Decimal(12, 2)
  paidOut     Boolean  @default(false)
  createdAt   DateTime @default(now())

  driver  User    @relation(fields: [driverId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([driverId])
  @@index([paidOut])
}


// ────────────────────────────────────────────────────────────────────────────
// Feature-Specific Media Tables
//
// Each entity has its own dedicated image/document table with proper foreign
// keys and Prisma relations. This replaces both the old String[] fields AND
// the polymorphic Media table from the previous iteration.
//
// Old fields (Stay.images, Vehicle.images, Attraction.images, User.avatarUrl,
// User.documents, Ticket.attachments) are kept temporarily during migration.
// Remove them once the data migration script has run successfully.
// ────────────────────────────────────────────────────────────────────────────

model StayImage {
  id            String    @id @default(cuid())
  stayId        String
  path          String
  filename      String
  mimeType      String
  size          Int
  isCover       Boolean   @default(false)
  sortOrder     Int       @default(0)
  thumbnailPath String?
  mediumPath    String?
  optimizedPath String?
  uploadedById  String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  stay Stay @relation(fields: [stayId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([stayId, sortOrder])
  @@index([stayId, isCover])
}

model VehicleImage {
  id            String    @id @default(cuid())
  vehicleId     String
  path          String
  filename      String
  mimeType      String
  size          Int
  isCover       Boolean   @default(false)
  sortOrder     Int       @default(0)
  thumbnailPath String?
  mediumPath    String?
  optimizedPath String?
  uploadedById  String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([vehicleId, sortOrder])
  @@index([vehicleId, isCover])
}

model AttractionImage {
  id            String    @id @default(cuid())
  attractionId  String
  path          String
  filename      String
  mimeType      String
  size          Int
  isCover       Boolean   @default(false)
  sortOrder     Int       @default(0)
  thumbnailPath String?
  mediumPath    String?
  optimizedPath String?
  uploadedById  String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([attractionId, sortOrder])
  @@index([attractionId, isCover])
}

model UserAvatar {
  id            String    @id @default(cuid())
  userId        String    @unique
  path          String
  filename      String
  mimeType      String
  size          Int
  uploadedById  String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model UserDocument {
  id            String    @id @default(cuid())
  userId        String
  label         String?
  path          String
  filename      String
  mimeType      String
  size          Int
  sortOrder     Int       @default(0)
  uploadedById  String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, sortOrder])
}

model TicketAttachment {
  id            String    @id @default(cuid())
  ticketId      String
  path          String
  filename      String
  mimeType      String
  size          Int
  sortOrder     Int       @default(0)
  uploadedById  String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([ticketId, sortOrder])
}

