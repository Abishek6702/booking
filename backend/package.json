{
  "name": "travelmate-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "postinstall": "npm run prisma:generate",
    "typecheck": "tsc --noEmit",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:push": "prisma db push --config prisma.config.ts",
    "migrate:media": "tsx scripts/migrate-media.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "redis": "^5.12.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.16.5",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.5",
    "pino-pretty": "^13.1.1",
    "prisma": "^7.7.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
