# ==============================================================================
# TravelMate backend — Docker Compose env file
#
# Copy this to `.env.docker` and fill in the real values, then run:
#
#     docker compose --env-file .env.docker up --build
#
# DATABASE_URL and DIRECT_URL are used BOTH at build time (so prisma generate
# can resolve the datasource) and at runtime (so the app can connect).
# ==============================================================================

# ── Database (Supabase) — REQUIRED ───────────────────────────────────────────
# Pooled connection — used by the app at runtime.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# Direct connection — used by Prisma for migrations/introspection.
# If you only have one URL, set both to the same value.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST_PORT=6379

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_HOST_PORT=4000
NODE_ENV=production
LOG_LEVEL=info
LOG_HTTP_REQUESTS=false
SERVICE_NAME=travelmate-backend

# ── Auth — REQUIRED ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-use-openssl-rand-hex-64
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-64
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Auth (optional) ───────────────────────────────────────────────────────────
ADMIN_REGISTRATION_CODE=
SUPER_ADMIN_ID=

# ── App surface ───────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8080,http://localhost:8081
FRONTEND_URL=http://localhost:8080
TRUST_PROXY=1

# ── Mail (optional in dev) ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Tunables ──────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
BOOKING_TAX_RATE=0.15
BOOKING_HOLD_DURATION_MINUTES=10
AUTH_RATE_LIMIT_MAX=10
BOOKING_RATE_LIMIT_MAX=30
SEARCH_RATE_LIMIT_MAX=100
DISABLE_JOBS=false
